# Application
APP_ENV=development
SERVER_PORT=8080
WS_PORT=8081

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=techapp
DB_PASS=techapp_secret
DB_NAME=techapp
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost:6379
REDIS_PASS=

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRY=15m
REFRESH_EXPIRY=720h

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_BUCKET=techapp-uploads

# Firebase
FIREBASE_PROJECT_ID=

# Google Maps
MAPS_API_KEY=

# Payment Gateway
PAYMENT_KEY=
PAYMENT_SECRET=

# Business Rules
COMMISSION_RATE=0.20
MAX_TECH_DEBT=500.00
MATCH_RADIUS_START=5000
MATCH_RADIUS_MAX=25000
MATCH_TIMEOUT_SECONDS=30
ARRIVAL_DISTANCE_METERS=100

# Monitoring
SENTRY_DSN=
